{
  "name": "allcoast",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "PORT=3001 tsx watch server/index.ts",
    "dev:client": "vite --host 127.0.0.1",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "lint": "tsc --noEmit",
    "test": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.20.0",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.2.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^5.4.0"
  }
}
